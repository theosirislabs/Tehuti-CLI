# Required: OpenRouter API Key
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Exa API Key for web/code search
# Get yours at https://exa.ai
EXA_API_KEY=your-exa-api-key-here

# Optional: Default model override
# TEHUTI_MODEL=anthropic/claude-sonnet-4

# Optional: Enable debug mode
# TEHUTI_DEBUG=true

# For GitHub MCP server (https://github.com/mcp/github/github-mcp-server)
# Create a PAT at https://github.com/settings/personal-access-tokens/new with 'repo' scope
# GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat-here
